generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Industry {
  DENTAL
  MEDICAL
  SALON
  GYM
  HOME_SERVICES
  RESTAURANT
  AUTO
  FITNESS
  OTHER
}

enum ReviewStatus {
  REDIRECTED_TO_GOOGLE
  PRIVATE_FEEDBACK
  ABANDONED
}

enum ReplyStatus {
  NEEDS_REPLY
  DRAFT
  REPLIED
}

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  passwordHash        String
  name                String?
  googleId            String?    @unique
  resetToken          String?
  resetTokenExpiresAt DateTime?
  suspended           Boolean    @default(false)
  suspendedAt         DateTime?
  suspendedReason     String?
  deletedAt           DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  businesses          Business[]
  sessions            Session[]
  activityLogs        ActivityLog[]
  subscriptions       Subscription[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Business {
  id              String   @id @default(cuid())
  userId          String
  name            String
  slug            String   @unique
  industry        Industry @default(OTHER)
  googleReviewUrl String?
  googlePlaceId   String?  // Google Place ID for Places API reviews (e.g., "ChIJN1t_tDeuEmsRUsoyG83frY4")
  location        String?
  phoneNumber     String?
  website         String?
  promptTopics    String[]
  emailTemplate   String?
  smsTemplate     String?

  // Branding
  logoUrl         String?
  primaryColor    String?    @default("#1c3a35")
  backgroundColor String?    @default("#ffffff")
  splashTagline   String?
  showPoweredBy   Boolean?   @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCodes         QrCode[]
  feedback        Feedback[]
  reviewDrafts    ReviewDraft[]
  reviewClicks    ReviewClick[]
  generatedReplies GeneratedReply[]
  activityLogs    ActivityLog[]
  googleAccount   GoogleAccount?
  googleReviews   GoogleReview[]
  whatsAppTemplates WhatsAppTemplate[]
  whatsAppFlows    WhatsAppFlow[]
  whatsAppFlowResponses WhatsAppFlowResponse[]
  reviewTasks      ReviewTask[]
  instagramMentions InstagramMention[]
  crossPlatformMessages CrossPlatformMessage[]
}

model QrCode {
  id         String   @id @default(cuid())
  businessId String
  type       String   @default("review")
  url        String
  createdAt  DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Feedback {
  id                  String       @id @default(cuid())
  businessId          String
  rating              Int
  purchaseInfo        String?
  liked               String?
  improvement         String?
  voiceNoteUrl        String?
  customerName        String?
  customerEmail       String?
  privateNote         String?
  selectedSubOptions  Json?        // Industry-specific category sub-option IDs selected by the customer
  status              ReviewStatus @default(PRIVATE_FEEDBACK)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  reviewDraft   ReviewDraft?
  reviewClicks  ReviewClick[]
  generatedReply GeneratedReply?
}

model ReviewDraft {
  id         String   @id @default(cuid())
  feedbackId String   @unique
  businessId String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ReviewClick {
  id         String       @id @default(cuid())
  feedbackId String
  businessId String
  type       String       @default("google_redirect")
  createdAt  DateTime     @default(now())

  feedback   Feedback     @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model GeneratedReply {
  id         String      @id @default(cuid())
  feedbackId String      @unique
  businessId String
  content    String
  tone       String      @default("professional")
  status     ReplyStatus @default(DRAFT)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  feedback   Feedback    @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model GoogleAccount {
  id               String    @id @default(cuid())
  businessId       String    @unique
  googleAccountId  String
  googleLocationId String?   // Google location ID for GBP API URL construction
  accessToken      String    @default("")  // Legacy plaintext — use tokenEncrypted for new connections
  refreshToken     String?                // Legacy plaintext — use tokenEncrypted
  tokenEncrypted   Json?                  // { accessToken: { encrypted, iv, tag }, refreshToken?: { encrypted, iv, tag } }
  tokenExpiresAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  googleReviews   GoogleReview[]
}

model GoogleReview {
  id             String   @id @default(cuid())
  googleReviewId String   @unique
  googleAccountId String
  businessId     String
  reviewerName   String?
  reviewerPhotoUrl String?
  starRating     Int
  comment        String?
  commentLanguage String?
  createTime     DateTime
  reviewReply    String?
  replyStatus    String   @default("NEEDS_REPLY")
  syncedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  googleAccount  GoogleAccount @relation(fields: [googleAccountId], references: [id], onDelete: Cascade)
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model SubscriptionPlan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  price         Int            // in paise (₹)
  interval      String         @default("month")
  aiCallsLimit  Int            @default(0)
  businessLimit Int            @default(1)
  features      String[]
  razorpayPlanId String?
  active        Boolean        @default(true)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                    String            @id @default(cuid())
  userId                String
  planId                String
  status                String            @default("created")
  razorpaySubscriptionId String?
  razorpayCustomerId    String?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  trialEnd              DateTime?
  aiCallsUsed           Int               @default(0)
  aiCallsLimit          Int               @default(0)
  businessLimit         Int               @default(1)
  cancelledAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                  SubscriptionPlan  @relation(fields: [planId], references: [id])
  invoices              Invoice[]
}

model Invoice {
  id                String       @id @default(cuid())
  subscriptionId    String
  razorpayPaymentId String?      @unique
  amount            Int          // in paise
  currency          String       @default("INR")
  status            String       @default("created")
  description       String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  subscription      Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  action     String
  details    Json?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// v2 Feature Models (isolated additions — do not modify existing models above)
// ---------------------------------------------------------------------------

enum FlowStatus {
  SENT
  OPENED
  COMPLETED
  EXPIRED
}

model WhatsAppTemplate {
  id         String   @id @default(cuid())
  businessId String
  name       String
  language   String   @default("en")
  category   String   @default("MARKETING")
  status     String   @default("APPROVED") // PENDING | APPROVED | REJECTED
  flowId     String?  // WhatsApp Flow ID (for interactive flows)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  flows    WhatsAppFlow[]
}

model WhatsAppFlow {
  id             String     @id @default(cuid())
  businessId     String
  templateId     String?
  customerPhone  String
  customerName   String?
  status         FlowStatus @default(SENT)
  flowSessionId  String?    @unique // WhatsApp Flow session ID
  expiresAt      DateTime?
  sentAt         DateTime   @default(now())
  completedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  business Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  template WhatsAppTemplate?   @relation(fields: [templateId], references: [id])
  response WhatsAppFlowResponse?
}

model WhatsAppFlowResponse {
  id              String   @id @default(cuid())
  flowId          String   @unique
  businessId      String
  rating          Int
  liked           String?
  improvement     String?
  customerName    String?
  customerEmail   String?
  privateNote     String?
  rawResponse     Json?
  createdAt       DateTime @default(now())

  flow     WhatsAppFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  business Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ReviewTask {
  id             String   @id @default(cuid())
  businessId     String
  title          String
  description    String?
  taskType       String   @default("follow_up") // follow_up | reply | review_request
  priority       String   @default("normal")    // low | normal | high
  status         String   @default("pending")   // pending | done | overdue
  source         String?  // "negative_review" | "overdue_reply" | "manual"
  referenceId    String?  // ID of the review/feedback that triggered this
  dueAt          DateTime?
  assignedTo     String?  // agent name or user id
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model InstagramMention {
  id              String   @id @default(cuid())
  businessId      String
  igMediaId       String   @unique
  igCommentId     String?  @unique
  mentionerName   String
  mentionerIgId   String
  commentText     String
  mediaType       String   @default("image") // image | video | carousel
  mediaUrl        String?
  permalink       String?
  isReply         Boolean  @default(false)
  parentCommentId String?
  sentiment       String?  // auto-detected: positive | neutral | negative
  replied         Boolean  @default(false)
  replyText       String?
  repliedAt       DateTime?
  syncedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model CrossPlatformMessage {
  id              String   @id @default(cuid())
  businessId      String
  platform        String   // "google" | "instagram" | "whatsapp" | "sms" | "email"
  externalId      String?  // ID on the platform
  direction       String   @default("inbound") // inbound | outbound
  authorName      String?
  authorPlatformId String?
  content         String
  contentType     String   @default("text")
  status          String   @default("unread") // unread | read | replied
  replyText       String?
  repliedAt       DateTime?
  conversationId  String?  // Group messages into conversations
  syncedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}
